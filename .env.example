# Turso (shared team cloud DB)
# Get these from: https://app.turso.tech -> your database -> Connect
TURSO_DATABASE_URL=libsql://your-db-name-yourname.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Your display name - attached to style rules you create or update
MEMOREE_USER=Alice

# Role:
#   reviewer -> can create, update, append, and delete style rules
#   member   -> read-only access (default for all developers)
MEMOREE_ROLE=member
