{
  "name": "hivemind",
  "displayName": "HiveMind",
  "description": "Persistent AI memory blocks and team coding style rules",
  "version": "0.2.0",
  "publisher": "hivemind",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other"],
  "icon": "media/icon.png",
  "activationEvents": [
    "onView:hivemind.sidebar",
    "onCommand:memoree.refresh"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "HiveMind",
      "properties": {
        "hivemind.tursoUrl": {
          "type": "string",
          "default": "",
          "description": "Turso database URL (e.g. libsql://your-db.turso.io). Required for cloud sync."
        },
        "hivemind.tursoToken": {
          "type": "string",
          "default": "",
          "description": "Turso auth token. Required for cloud sync."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hivemind-container",
          "title": "HiveMind",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "hivemind-container": [
        {
          "type": "webview",
          "id": "hivemind.sidebar",
          "name": "HiveMind"
        }
      ]
    }
  },
  "scripts": {
    "build": "/home/kedar/.nvm/versions/node/v22.22.0/bin/node node_modules/typescript/bin/tsc -p tsconfig.json",
    "watch": "/home/kedar/.nvm/versions/node/v22.22.0/bin/node node_modules/typescript/bin/tsc --watch -p tsconfig.json",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "uuid": "^11.0.5"
  }
}
